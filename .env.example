# =============================================================================
# 复制本文件为项目根目录的 .env（与 server/ 同级）。切勿提交真实 .env。
# =============================================================================

NODE_ENV=development
PORT=3780

# 监听地址：生产默认 127.0.0.1（仅本机 + Nginx 反代）；直连公网可改为 0.0.0.0 并配防火墙
# BIND_HOST=127.0.0.1

# JWT（必填，≥16 字符）
JWT_SECRET=请替换为至少16位的随机字符串
# JWT_EXPIRES_IN=7d

# ---------- MySQL（生产必填）----------
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=aishigong
MYSQL_PASSWORD=
MYSQL_DATABASE=construction_demo
# MYSQL_CONNECTION_LIMIT=10

# ---------- 生产种子策略 ----------
# production 下默认为 false：不写演示项目/账号：须首次用 ADMIN_BOOTSTRAP_* 创建管理员
# development 下默认为 true（等同未设置）
# SEED_DEMO_DATA=false

# 空库且无演示种子时创建首个管理员（密码建议≥12位，登录成功后从环境中删除）
# ADMIN_BOOTSTRAP_USERNAME=
# ADMIN_BOOTSTRAP_PASSWORD=
# ADMIN_BOOTSTRAP_DISPLAY_NAME=系统管理员

# BCRYPT_ROUNDS=12

# ---------- 可选 AI ----------
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# WAVESPEED_API_KEY=
# WAVESPEED_TEXT_TO_IMAGE_MODEL=alibaba/wan-2.6/text-to-image

# ---------- 安全 / 反代 ----------
# TRUST_PROXY=true
# TRUST_PROXY_HOPS=1

# 逗号分隔；生产若前端不同域须配置。未配置且 NODE_ENV=production 时不放行跨域
# CORS_ORIGIN=https://your-domain.com

# SERVE_REPO_ROOT=false

# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=400
# LOGIN_RATE_LIMIT_WINDOW_MS=900000
# LOGIN_RATE_LIMIT_MAX=40
