{
  "contract_version": "0.2.0",
  "status": "draft",
  "description": "案例驱动验收与履约的最小 REST 契约（与 PRJ-DEMO-001 / scenario-120 演示对齐）；未实现的路由为产品化预留。",
  "case_anchor": {
    "project_code": "PRJ-DEMO-001",
    "scenario_meta": "GET /api/meta/scenario",
    "room_cases_file": "server/scenario-120-room-cases.json",
    "procurement_demo": "GET /api/meta/procurement-ai",
    "ai_showcase": "GET /api/meta/ai-showcase"
  },
  "common": {
    "auth": "Bearer JWT（除公开 meta 外，生产环境建议全部需登录）",
    "content_type": "application/json; charset=utf-8",
    "idempotency_header": "Idempotency-Key（可选，用于证据重复提交）",
    "error_shape": {
      "error": "string",
      "code": "string?",
      "details": "object?"
    }
  },
  "entities": {
    "Case": {
      "fields": {
        "id": "string（如 PRJ-DEMO-001）",
        "title": "string",
        "area_sqm": "number",
        "status": "enum: design|construction|delivery|warranty",
        "template_id": "string?（闸口模板）"
      }
    },
    "AcceptanceGate": {
      "fields": {
        "gate_id": "string（concealed|masonry_mep|completion|warranty）",
        "name": "string",
        "priority": "P0|P1",
        "status": "enum: locked|pending_evidence|ai_draft|awaiting_human|passed|rejected",
        "blocks_payment_ready": "boolean"
      }
    },
    "EvidenceArtifact": {
      "fields": {
        "artifact_id": "uuid",
        "kind": "enum: image|pdf|curve|report|measurement_set",
        "storage_uri": "string",
        "content_hash": "string（sha256）",
        "captured_at": "iso8601",
        "algorithm_version": "string?",
        "zone": "string?（房间标签）",
        "linked_bim_node_id": "string?"
      }
    },
    "AcceptanceRecord": {
      "fields": {
        "record_id": "uuid",
        "case_id": "string",
        "gate_id": "string",
        "module": "enum: dim|waterproof|hydraulic|hollow|iaq|other",
        "ai_verdict": "enum: pass|fail|review|na",
        "ai_explain_md": "string?",
        "human_signoff": "enum: pending|approved|overruled_with_reason",
        "signed_by": "user_id?",
        "signed_at": "iso8601?"
      }
    },
    "PaymentReadiness": {
      "fields": {
        "milestone_code": "string",
        "score_0_100": "number",
        "blocking_gates": "string[]"
      }
    }
  },
  "endpoints_implemented_demo": [
    {
      "method": "GET",
      "path": "/api/meta/scenario",
      "response": "{ data: Scenario120Meta }",
      "note": "含 room_cases、角色流、图库"
    },
    {
      "method": "GET",
      "path": "/api/meta/case-flow-contract",
      "response": "{ data: 本 JSON }",
      "note": "契约自述"
    },
    {
      "method": "GET",
      "path": "/api/meta/ai-showcase",
      "response": "{ data: AiConstructionShowcaseDoc }"
    },
    {
      "method": "GET",
      "path": "/api/meta/procurement-ai",
      "response": "{ data: ProcurementAiDemoDoc }"
    }
  ],
  "endpoints_product_backlog": [
    {
      "method": "GET",
      "path": "/api/v1/cases/{caseId}",
      "response": "{ data: Case }"
    },
    {
      "method": "GET",
      "path": "/api/v1/cases/{caseId}/gates",
      "response": "{ data: AcceptanceGate[] }"
    },
    {
      "method": "GET",
      "path": "/api/v1/cases/{caseId}/gates/{gateId}/records",
      "response": "{ data: AcceptanceRecord[], page }"
    },
    {
      "method": "POST",
      "path": "/api/v1/cases/{caseId}/gates/{gateId}/evidence",
      "body": "{ artifacts: EvidenceArtifact[], zone?, module? }",
      "response": "{ data: { batch_id, artifact_ids[] } }"
    },
    {
      "method": "POST",
      "path": "/api/v1/cases/{caseId}/gates/{gateId}/ai-evaluate",
      "body": "{ record_hint?, artifact_ids[] }",
      "response": "{ data: AcceptanceRecord }",
      "note": "异步时可返回 job_id"
    },
    {
      "method": "PATCH",
      "path": "/api/v1/cases/{caseId}/gates/{gateId}/records/{recordId}/signoff",
      "body": "{ decision: approved|overruled_with_reason, reason? }",
      "response": "{ data: AcceptanceRecord }"
    },
    {
      "method": "GET",
      "path": "/api/v1/cases/{caseId}/payment-readiness",
      "response": "{ data: PaymentReadiness[] }",
      "note": "与合同里程碑对齐"
    }
  ]
}
