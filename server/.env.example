# 复制到项目根目录的 .env（与 server 同级），或在本文件同目录单独维护。
# 已有 DEEPSEEK_API_KEY、WAVESPEED_* 等保持不变。

PORT=3780

# 工作台登录必需（≥16 字符）；与旧配置 JWT_EXPIRES_IN 可共存
JWT_SECRET=请替换为至少16位的随机字符串
# JWT_EXPIRES_IN=7d

# MySQL（可选；未配置或连接失败时使用内存模拟数据）
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=construction_demo

# DeepSeek（可选覆盖）
# DEEPSEEK_MODEL=deepseek-chat
