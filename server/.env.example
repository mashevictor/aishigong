# 完整变量说明与生产默认值见仓库根目录：../.env.example
# 应用从「项目根目录」加载 .env（与 server 同级），复制根目录 .env.example 为 ../.env 即可。

PORT=3780
JWT_SECRET=请替换为至少16位的随机字符串
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=construction_demo

# 可选：批量生成 120㎡ 演示场景图（npm run scenario:images）
# 仅重生成指定 ID（示例：玄关/餐厅/次卧/阳台现场）：npm run scenario:images:cn-four
# WAVESPEED_API_KEY=...
# WAVESPEED_TEXT_TO_IMAGE_MODEL=alibaba/wan-2.6/text-to-image
# WAVESPEED_TEXT_TO_IMAGE_MODEL_ALT=alibaba/alibaba-wan-2.6-text-to-image
# DEEPSEEK_API_KEY=（可选：工作台文生文 / scenario:images / showcase:deepseek / case:rooms-deepseek 按房间补充争议案例）
# SCENARIO_IMAGE_DELAY_MS=1500
# SCENARIO_IMAGE_LIMIT=（可选，仅生成前 N 张）
